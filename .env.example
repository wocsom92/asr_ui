SECRET_KEY=change-me-in-production-use-a-long-random-string
DATABASE_URL=sqlite+aiosqlite:////data/asr_ui.db
CORS_ORIGINS=["http://localhost:5173","http://localhost:8824"]
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DATA_DIR=/data
UPLOADS_DIR=/data/uploads
OUTPUTS_DIR=/data/transcripts
MODELS_DIR=/models
MAX_UPLOAD_MB=2048
WHISPER_CPP_BIN=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_THREADS=4
# 0 disables cross-window text context, which prevents one hallucinated segment
# from poisoning the rest of a long recording.
WHISPER_MAX_CONTEXT=0
# Set true only when whisper.cpp is built for your GPU stack (CUDA/Vulkan/Metal) and stable.
WHISPER_USE_GPU=false
WHISPER_FLASH_ATTN=false
# Optional regex removed from generated transcripts. Leave empty to disable.
TRANSCRIPT_FILTER_REGEX=
TRANSCRIPTION_POLL_SECONDS=2
ASR_WORKER_ENABLED=true
# Stable identity for the local backend worker. Keep this unchanged across redeploys
# if you want the same worker database row/id to be reused.
ASR_WORKER_NAME=raspi5
ASR_WORKER_TOKEN=change-me-worker-token
ASR_SERVER_URL=http://127.0.0.1:8825
ASR_WORKER_CONCURRENCY=1
ASR_WORKER_AUTO_INSTALL_MODELS=true
ASR_WORKER_HEARTBEAT_SECONDS=5
ASR_WORKER_OFFLINE_SECONDS=20
ASR_SPLIT_MIN_CHUNK_SECONDS=300
ASR_SPLIT_OVERLAP_SECONDS=5
ASR_SPLIT_MAX_CHUNKS=8
GIGAAM_CHUNK_MAX_SECONDS=24.0
GIGAAM_CHUNK_TARGET_SECONDS=22.0
GIGAAM_CHUNK_OVERLAP_SECONDS=1.0
GIGAAM_VAD_ENABLED=true
GIGAAM_VAD_MODE=2
GIGAAM_VAD_MERGE_SILENCE_MS=500
GIGAAM_VAD_PAD_MS=200
# Raspberry Pi 5 defaults. Use 4 or higher for a MacBook worker.
GIGAAM_TORCH_THREADS=3
GIGAAM_TORCH_INTEROP_THREADS=1
SUMMARIZATION_OLLAMA_BASE_URL=http://ollama:11434
TELEGRAM_PROXY_URL=http://host.docker.internal:18081
ASR_TELEGRAM_EGRESS_PROXY_LISTEN_HOST=0.0.0.0
ASR_TELEGRAM_EGRESS_PROXY_LISTEN_PORT=18081
# Bind Telegram egress to a VPN interface on hosts where direct Telegram is blocked.
# raspi5 uses amnezia.
ASR_TELEGRAM_EGRESS_PROXY_BIND_INTERFACE=
ASR_TELEGRAM_EGRESS_PROXY_LOCAL_ADDRESS=
ASR_TELEGRAM_EGRESS_PROXY_UPSTREAM_PROXY_URL=
FRONTEND_PORT=8824
BACKEND_PORT=8825
# Optional Docker build base image overrides. Defaults use Docker Hub official images.
# BACKEND_PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
# FRONTEND_NODE_IMAGE=public.ecr.aws/docker/library/node:20-alpine
# FRONTEND_NGINX_IMAGE=public.ecr.aws/docker/library/nginx:alpine
