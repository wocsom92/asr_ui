# ──────────────────────────────────────────────────────
# Deploy targets configuration for ASR UI
# ──────────────────────────────────────────────────────

TARGET_raspi5_HOST="raspberrypi.local"
TARGET_raspi5_PORT="22"
TARGET_raspi5_USER="pi"
TARGET_raspi5_DEPLOY_PATH="/home/pi/asr_ui"
TARGET_raspi5_AUTH="key"
TARGET_raspi5_KEY_PATH="${HOME}/.ssh/id_ed25519"
TARGET_raspi5_PASSWORD=""
TARGET_raspi5_ENV_FILE=".env"
TARGET_raspi5_REMOTE_ENV_NAME=".env"
TARGET_raspi5_DOCKER_USE_SUDO="true"
TARGET_raspi5_PURGE_MODE="managed"
