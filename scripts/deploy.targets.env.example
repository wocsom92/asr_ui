# ──────────────────────────────────────────────────────
# Deploy targets configuration for ASR UI
# ──────────────────────────────────────────────────────

TARGET_raspi5_HOST="raspberrypi.local"
TARGET_raspi5_PORT="22"
TARGET_raspi5_USER="pi"
TARGET_raspi5_DEPLOY_PATH="/home/pi/asr_ui"
TARGET_raspi5_AUTH="key"
TARGET_raspi5_KEY_PATH="${HOME}/.ssh/id_ed25519"
TARGET_raspi5_PASSWORD=""
TARGET_raspi5_ENV_FILE=".env"
TARGET_raspi5_REMOTE_ENV_NAME=".env"
TARGET_raspi5_WORKER_NAME="raspi5"
TARGET_raspi5_DOCKER_USE_SUDO="true"
TARGET_raspi5_PURGE_MODE="managed"
TARGET_raspi5_GIGAAM_TORCH_THREADS="3"
TARGET_raspi5_GIGAAM_TORCH_INTEROP_THREADS="1"

# Local MacBook worker only. This target does not SSH anywhere; it runs:
# docker compose --profile worker up -d --build worker
TARGET_macbook_worker_MODE="local-worker"
TARGET_macbook_worker_ENV_FILE=".env"
TARGET_macbook_worker_WORKER_NAME="macbook"
TARGET_macbook_worker_SERVER_URL="http://raspberrypi.local:8825"
TARGET_macbook_worker_GIGAAM_TORCH_THREADS="4"
TARGET_macbook_worker_GIGAAM_TORCH_INTEROP_THREADS="1"
